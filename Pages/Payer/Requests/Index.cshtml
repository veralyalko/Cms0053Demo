@page
@model Cms0053Demo.Pages.Payer.Requests.IndexModel
@{ ViewData["Title"] = "Attachment Requests"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="badge bg-primary mb-1">Payer Portal</span>
        <h2 class="fw-bold mb-0">Attachment Requests</h2>
    </div>
    <a href="/Payer/Requests/Create" class="btn btn-primary">+ New Request</a>
</div>

@if (!Model.Requests.Any())
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            No attachment requests yet. Create one to start the solicited workflow.
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tracking #</th>
                    <th>Claim</th>
                    <th>Patient</th>
                    <th>Document Requested</th>
                    <th>Requested</th>
                    <th>Due</th>
                    <th>Status</th>
                    <th>Upload Link</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model.Requests)
                {
                    var statusClass = req.Status == "Fulfilled" ? "bg-success" :
                                     req.Status == "Pending"   ? "bg-warning text-dark" :
                                     req.Status == "Expired"   ? "bg-secondary" : "bg-danger";
                    var isOverdue = req.Status == "Pending" && req.DueDate < DateTime.UtcNow;
                    <tr>
                        <td class="font-monospace small text-muted">@req.TrackingNumber</td>
                        <td class="small fw-semibold">@req.Claim.ClaimNumber</td>
                        <td class="small">@req.Claim.PatientName</td>
                        <td class="small">@req.DocumentTypeRequested</td>
                        <td class="small text-muted">@req.RequestedAt.ToString("MM/dd/yyyy")</td>
                        <td class="small @(isOverdue ? "text-danger fw-semibold" : "text-muted")">
                            @req.DueDate.ToString("MM/dd/yyyy")
                            @if (isOverdue) { <span class="badge bg-danger ms-1 small">Overdue</span> }
                        </td>
                        <td><span class="badge @statusClass small">@req.Status</span></td>
                        <td>
                            @if (req.Status == "Pending")
                            {
                                <a href="/Provider/Upload/@req.SecureUploadToken"
                                   class="btn btn-sm btn-outline-success py-0 px-2"
                                   target="_blank">Open Upload Link</a>
                            }
                            @if (req.Transactions.Any())
                            {
                                <a href="/Payer/Attachments/Detail/@req.Transactions.First().Id"
                                   class="btn btn-sm btn-outline-primary py-0 px-2 ms-1">View Result</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
