@page
@model Cms0053Demo.Pages.Provider.DirectSubmitModel
@{ ViewData["Title"] = "Direct Submission"; }

<div class="d-flex align-items-center gap-2 mb-1">
    <span class="badge bg-success">Provider Portal</span>
    <span class="text-muted small">/ Direct Submission</span>
</div>
<h2 class="fw-bold mb-1">Submit Claim Attachment</h2>
<p class="text-muted mb-4">
    Submit a C-CDA clinical document directly to Meridian Health Plan.
    Select a document from your EMR or upload a C-CDA XML file.
    <span class="badge bg-light text-secondary border small ms-1">X12 275 unsolicited direct</span>
</p>

<form method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-7">

            <div class="card mb-3">
                <div class="card-header py-2"><strong>1. Provider &amp; Patient Information</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Claim Number</label>
                            <input asp-for="ClaimNumber" class="form-control" placeholder="e.g. CLM-A-2026-0047"
                                   list="claimSuggestions" required />
                            <datalist id="claimSuggestions">
                                @foreach (var c in Model.Claims)
                                {
                                    <option value="@c.ClaimNumber">@c.PatientName</option>
                                }
                            </datalist>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Provider NPI</label>
                            <input asp-for="ProviderNPI" class="form-control" placeholder="10 digits"
                                   pattern="\d{10}" maxlength="10" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Provider Name</label>
                            <input asp-for="ProviderName" class="form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Patient Name</label>
                            <input asp-for="PatientName" class="form-control" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Patient DOB</label>
                            <input asp-for="PatientDOBString" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Service Date</label>
                            <input asp-for="ServiceDateString" type="date" class="form-control" required />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2"><strong>2. Document Type</strong></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-7 mb-3">
                            <label class="form-label">Document Type</label>
                            <select asp-for="DocumentType" class="form-select" required
                                    onchange="syncLoinc(this)">
                                <option value="">-- Select --</option>
                                <option value="Discharge Summary" data-loinc="18842-5">Discharge Summary</option>
                                <option value="Operative Note" data-loinc="11504-8">Operative Note</option>
                                <option value="History and Physical Note" data-loinc="34117-2">History and Physical Note</option>
                                <option value="Lab Results" data-loinc="26436-6">Lab Results</option>
                                <option value="Radiology Report" data-loinc="18748-4">Radiology Report</option>
                                <option value="Office Visit Notes" data-loinc="11488-4">Office Visit Notes</option>
                            </select>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">LOINC Code</label>
                            <input asp-for="LoincCode" class="form-control font-monospace" required />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Notes <span class="text-muted">(optional)</span></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2"><strong>3. Clinical Document</strong></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Select from EMR (Synthea-generated)</label>
                        <select asp-for="EmrDocumentId" class="form-select"
                                onchange="autofillFromEmr(this)">
                            <option value="">-- Upload your own below --</option>
                            @foreach (var doc in Model.EmrDocuments)
                            {
                                <option value="@doc.Id"
                                        data-patient="@doc.PatientName"
                                        data-dob="@doc.PatientDOB.ToString("yyyy-MM-dd")"
                                        data-npi="@doc.ProviderNPI"
                                        data-provider="@doc.ProviderName"
                                        data-service="@doc.ServiceDate.ToString("yyyy-MM-dd")"
                                        data-doctype="@doc.DocumentType"
                                        data-loinc="@doc.LoincCode">
                                    @doc.DocumentName
                                </option>
                            }
                        </select>
                        <div class="form-text">These are Synthea-generated C-CDA documents pre-loaded for demo use.</div>
                    </div>
                    <div class="text-center text-muted small my-2">— OR —</div>
                    <div>
                        <label class="form-label">Upload C-CDA XML File</label>
                        <input asp-for="UploadedFile" type="file" class="form-control"
                               accept=".xml,.cda,text/xml,application/xml" />
                        <div class="form-text">Upload a valid C-CDA R2.1 XML document.</div>
                    </div>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Submit Attachment &rarr;</button>
                <a href="/" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-light">
                <div class="card-header py-2 bg-light"><strong>Open Claims</strong></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>Claim</th><th>Patient</th><th>Amount</th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.Claims)
                            {
                                <tr style="cursor:pointer" onclick="fillClaim('@c.ClaimNumber','@c.ProviderNPI','@c.ProviderName','@c.PatientName','@c.PatientDOB.ToString("yyyy-MM-dd")','@c.ServiceDate.ToString("yyyy-MM-dd")')">
                                    <td class="small fw-semibold">@c.ClaimNumber</td>
                                    <td class="small">@c.PatientName</td>
                                    <td class="small text-muted">@c.AmountBilled.ToString("C0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
function fillClaim(claimNum, npi, provider, patient, dob, svcDate) {
    document.getElementById('ClaimNumber').value  = claimNum;
    document.getElementById('ProviderNPI').value  = npi;
    document.getElementById('ProviderName').value = provider;
    document.getElementById('PatientName').value  = patient;
    document.getElementById('PatientDOBString').value  = dob;
    document.getElementById('ServiceDateString').value = svcDate;
}

function autofillFromEmr(sel) {
    if (!sel.value) return;
    var opt = sel.options[sel.selectedIndex];
    document.getElementById('PatientName').value       = opt.dataset.patient;
    document.getElementById('PatientDOBString').value  = opt.dataset.dob;
    document.getElementById('ProviderNPI').value       = opt.dataset.npi;
    document.getElementById('ProviderName').value      = opt.dataset.provider;
    document.getElementById('ServiceDateString').value = opt.dataset.service;
    document.getElementById('DocumentType').value      = opt.dataset.doctype;
    document.getElementById('LoincCode').value         = opt.dataset.loinc;
    // Find matching claim
    @foreach (var c in Model.Claims)
    {
        @:if (opt.dataset.npi === '@c.ProviderNPI') document.getElementById('ClaimNumber').value = '@c.ClaimNumber';
    }
}

function syncLoinc(sel) {
    var opt = sel.options[sel.selectedIndex];
    if (opt && opt.dataset.loinc)
        document.getElementById('LoincCode').value = opt.dataset.loinc;
}
</script>
}
