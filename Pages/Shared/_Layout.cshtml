<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Meridian Health Plan</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: -.5px; }
        .navbar { border-bottom: 3px solid #0d6efd; }
        .screen-badge { font-size: .65rem; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; }
        .stage-row { transition: background .2s; }
        .stage-row.running { background: #fff3cd; }
        .stage-row.passed  { background: #d1e7dd; }
        .stage-row.failed  { background: #f8d7da; }
        .hash-cell { font-family: monospace; font-size: .72rem; word-break: break-all; }
        .pain-stat { font-size: 2.8rem; font-weight: 700; line-height: 1; }
        .timeline-bar { height: 24px; border-radius: 4px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-0">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-page="/Index">
                <span class="text-primary">iX</span>DataBridge
                <span class="badge bg-primary ms-2 fw-normal" style="font-size:.65rem">CMS-0053</span>
            </a>
            <div class="navbar-collapse collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/TodaysReality">S1</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/Compliance">S2</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/TradingPartner">S3</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/Pipeline">S4</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/Repository">S5</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/ClaimsHandoff">S6</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Demo/AuditTrail">S7</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link text-warning fw-semibold" asp-page="/Presenter/Console">Presenter</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 py-3">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
