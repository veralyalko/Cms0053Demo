@page
@model Cms0053Demo.Pages.IndexModel
@{ ViewData["Title"] = "CMS-0053 Attachment Platform"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">CMS-0053 Claim Attachment Platform</h2>
        <p class="text-muted mb-0">Meridian Health Plan &mdash; iXDataBridge</p>
    </div>
    @if (Model.TotalTransactionsCount > 0)
    {
        <form method="post" asp-page-handler="Reset">
            <button type="submit" class="btn btn-sm btn-outline-secondary"
                    onclick="return confirm('Reset all transactions, requests, and clearinghouse records?')">
                Reset Demo Data
            </button>
        </form>
    }
</div>

@* ── Summary stats ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card border-primary h-100">
            <div class="card-body text-center">
                <div class="display-6 fw-bold text-primary">@Model.OpenClaimsCount</div>
                <div class="small text-muted mt-1">Open Claims</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-warning h-100">
            <div class="card-body text-center">
                <div class="display-6 fw-bold text-warning">@Model.PendingRequestsCount</div>
                <div class="small text-muted mt-1">Pending Requests</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-info h-100">
            <div class="card-body text-center">
                <div class="display-6 fw-bold text-info">@Model.ClearinghouseQueueCount</div>
                <div class="small text-muted mt-1">Clearinghouse Queue</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-success h-100">
            <div class="card-body text-center">
                <div class="display-6 fw-bold text-success">@Model.TotalTransactionsCount</div>
                <div class="small text-muted mt-1">Attachments Received</div>
            </div>
        </div>
    </div>
</div>

@* ── Portal entry points ── *@
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100 border-primary">
            <div class="card-header bg-primary text-white py-2">
                <strong>Payer Portal</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Review incoming attachments, create solicited requests, view pipeline results and audit trails.</p>
                <div class="d-grid gap-2">
                    <a href="/Payer/Dashboard" class="btn btn-primary">Payer Dashboard</a>
                    <a href="/Payer/Requests/Create" class="btn btn-outline-primary">Create Attachment Request</a>
                    <a href="/Payer/Requests/Index" class="btn btn-outline-secondary btn-sm">View All Requests</a>
                    <a href="/Clearinghouse/Queue" class="btn btn-outline-secondary btn-sm">Clearinghouse Queue (@Model.ClearinghouseQueueCount pending)</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-success">
            <div class="card-header bg-success text-white py-2">
                <strong>Provider Portal</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Submit claim attachments directly or via the clearinghouse. Upload C-CDA documents or select from EMR records.</p>
                <div class="d-grid gap-2">
                    <a href="/Provider/DirectSubmit" class="btn btn-success">Direct Submission</a>
                    <a href="/Clearinghouse/Submit" class="btn btn-outline-success">Submit via Clearinghouse</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-secondary">
            <div class="card-header bg-secondary text-white py-2">
                <strong>About This Platform</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-2">CMS-0053-F compliant electronic claim attachment workflow. Three submission paths:</p>
                <ul class="small text-muted mb-3">
                    <li><strong>Solicited:</strong> Payer requests → provider uploads</li>
                    <li><strong>Clearinghouse:</strong> Provider → Veridian Exchange → payer pulls</li>
                    <li><strong>Direct:</strong> Provider submits directly via X12 275</li>
                </ul>
                <p class="small text-muted mb-0">All paths run the same 8-stage validation pipeline: X12 parse → CDA schema → C-CDA template → Schematron → LOINC → XMLDSig → claim match → audit hash.</p>
            </div>
        </div>
    </div>
</div>

@* ── Recent activity ── *@
@if (Model.RecentTransactions.Any())
{
    <h5 class="fw-semibold mb-2">Recent Activity</h5>
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tracking #</th>
                    <th>Patient</th>
                    <th>Provider</th>
                    <th>Document Type</th>
                    <th>Source</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in Model.RecentTransactions)
                {
                    var statusClass = tx.Status == "Routed" ? "bg-success" :
                                     tx.Status == "Failed"  ? "bg-danger"  : "bg-secondary";
                    var sourceLabel = tx.SourceType switch
                    {
                        "Solicited"               => "Solicited",
                        "UnsolicitedClearinghouse" => "Clearinghouse",
                        _                          => "Direct"
                    };
                    <tr>
                        <td class="font-monospace small">@tx.TrackingNumber</td>
                        <td>@tx.PatientName</td>
                        <td class="small text-muted">@tx.ProviderName</td>
                        <td class="small">@tx.DocumentType</td>
                        <td><span class="badge bg-secondary small">@sourceLabel</span></td>
                        <td><span class="badge @statusClass small">@tx.Status</span></td>
                        <td><a href="/Payer/Attachments/Detail/@tx.Id" class="btn btn-xs btn-outline-primary btn-sm py-0 px-2">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
