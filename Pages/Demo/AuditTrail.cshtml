@page
@model Cms0053Demo.Pages.Demo.AuditTrailModel
@using Cms0053Demo.Models
@using Cms0053Demo.Services
@{
    ViewData["Title"] = "Audit Trail";
    var tx   = Model.Transaction;
    var scen = Model.Scenario;
    var color = scen?.Code switch { "A" => "primary", "B" => "danger", "C" => "warning", _ => "secondary" };
}

<style>
    .chain-block {
        border: 1px solid #dee2e6; border-radius: 8px;
        background: #fff; position: relative;
    }
    .chain-block.genesis { background: #1a1a2e; color: #e0e0e0; border-color: #333; }
    .chain-connector {
        width: 2px; height: 24px; background: #adb5bd;
        margin: 0 auto;
    }
    .hash-mono { font-family: 'Consolas','Courier New',monospace; font-size:.72rem; word-break: break-all; }
    .prev-match { color: #198754; font-size:.65rem; }
    .chain-num { width:28px; height:28px; border-radius:50%; display:flex; align-items:center;
                 justify-content:center; font-size:.75rem; font-weight:700; flex-shrink:0; }
    @@keyframes blockIn {
        from { opacity:0; transform:translateY(6px); }
        to   { opacity:1; transform:translateY(0); }
    }
    .block-anim { opacity:0; animation:blockIn .3s ease forwards; }
</style>

@if (tx is null)
{
    <div class="mt-5 text-center text-muted">
        <p class="fs-5">No transaction loaded.</p>
        <a href="/" class="btn btn-primary">Select a Scenario</a>
    </div>
}
else
{
    @* ── Scenario header ── *@
    <div class="card border-@color mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center flex-wrap gap-3">
                <span class="badge bg-@color fs-6 px-3 py-2">Scenario @scen!.Code</span>
                <div>
                    <div class="fw-semibold">@scen.Title</div>
                    <small class="text-muted">@tx.PatientName &nbsp;·&nbsp; @tx.TrackingNumber</small>
                </div>
                <div class="ms-auto">
                    @if (Model.ChainValid)
                    {
                        <span class="badge bg-success fs-6 px-3">✓ Chain Verified</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6 px-3">✗ Chain Broken</span>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Screen nav ── *@
    <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom small">
        <a href="/Demo/ClaimsHandoff?transactionId=@tx.Id" class="btn btn-sm btn-outline-secondary">← Screen 6: Claims Handoff</a>
        <span class="ms-auto text-muted">Screen <strong>7</strong> of 7 — Audit Trail</span>
        <a href="/" class="btn btn-sm btn-outline-primary">← Home</a>
    </div>

    @* ── Chain integrity banner ── *@
    @if (Model.ChainValid)
    {
        <div class="alert alert-success d-flex align-items-center gap-3 mb-4">
            <span style="font-size:1.8rem">🔒</span>
            <div>
                <strong class="fs-5">Hash Chain Verified</strong>
                <div>@Model.Events.Count events &nbsp;·&nbsp; SHA-256 chain integrity confirmed &nbsp;·&nbsp; 0 tampering indicators detected</div>
                <div class="mt-1 small text-muted">Each block's PreviousHash matches the EventHash of the preceding block</div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger d-flex align-items-center gap-3 mb-4">
            <span style="font-size:1.8rem">⚠️</span>
            <div>
                <strong class="fs-5">Chain Integrity Failed</strong>
                <div>One or more hash values do not match — possible tampering detected</div>
            </div>
        </div>
    }

    @* ── Hash chain visualization ── *@
    <div class="row justify-content-center">
        <div class="col-lg-9">

            @* Genesis block *@
            <div class="chain-block genesis p-3 mb-0 block-anim" style="animation-delay:0s">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-secondary">GENESIS</span>
                    <span class="small text-muted">Origin block — no previous hash</span>
                </div>
                <div class="hash-mono" style="color:#80cbc4">@AuditHashService.GenesisHash</div>
            </div>

            @for (var i = 0; i < Model.Events.Count; i++)
            {
                var ev = Model.Events[i];
                var delay = (0.1 + i * 0.12).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                var prevHash = i == 0 ? AuditHashService.GenesisHash : Model.Events[i - 1].EventHash;
                var prevMatches = string.Equals(ev.PreviousHash, prevHash, StringComparison.OrdinalIgnoreCase);

                @* Connector arrow *@
                <div class="chain-connector block-anim" style="animation-delay:@(delay)s"></div>

                @* Event block *@
                <div class="chain-block p-3 block-anim" style="animation-delay:@(delay)s">
                    <div class="d-flex align-items-start gap-2">
                        <div class="chain-num bg-dark text-white">@(i + 1)</div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge @AuditTrailModel.EventBadgeClass(ev.EventType)" style="font-size:.65rem">@ev.EventType</span>
                                <span class="text-muted small">@ev.OccurredAt.ToString("HH:mm:ss.fff") UTC</span>
                            </div>
                            <div class="small mb-2">@ev.Description</div>
                            <div class="row g-1">
                                <div class="col-12">
                                    <span class="text-muted" style="font-size:.65rem; text-transform:uppercase; letter-spacing:.05em">PrevHash</span>
                                    <div class="hash-mono text-muted" style="font-size:.68rem">@AuditTrailModel.HashAbbrev(ev.PreviousHash)</div>
                                    @if (prevMatches)
                                    {
                                        <div class="prev-match">✓ matches block @(i == 0 ? "GENESIS" : $"#{i}")</div>
                                    }
                                    else
                                    {
                                        <div style="color:#dc3545; font-size:.65rem">✗ mismatch — chain broken</div>
                                    }
                                </div>
                                <div class="col-12 mt-1">
                                    <span class="text-muted" style="font-size:.65rem; text-transform:uppercase; letter-spacing:.05em">EventHash (SHA-256)</span>
                                    <div class="hash-mono" style="font-size:.68rem; color:#1a73e8">@AuditTrailModel.HashAbbrev(ev.EventHash)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (Model.Events.Count == 0)
            {
                <div class="chain-connector"></div>
                <div class="text-center text-muted p-4">No audit events recorded for this transaction</div>
            }
        </div>
    </div>

    <div class="mt-4 d-flex justify-content-center gap-3">
        <a href="/" class="btn btn-outline-secondary">← Run Another Scenario</a>
        <a href="/Demo/Pipeline?transactionId=@tx.Id" class="btn btn-outline-primary">Back to Pipeline</a>
    </div>
}
