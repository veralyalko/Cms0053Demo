@page
@model Cms0053Demo.Pages.Demo.TodaysRealityModel
@{ ViewData["Title"] = "Today's Reality"; }

<style>
    .pain-stat { font-size: 2.8rem; font-weight: 700; line-height: 1; }
    .stat-label { font-size: .8rem; text-transform: uppercase; letter-spacing: .08em; color: #6c757d; margin-top: .35rem; }
    .stat-source { font-size: .65rem; color: #adb5bd; margin-top: .2rem; }
    .workflow-step { border: 1px solid #dee2e6; border-radius: 8px; padding: 1rem; text-align: center; position: relative; }
    .workflow-step .step-days { font-size: 1.4rem; font-weight: 700; color: #dc3545; }
    .workflow-step .step-label { font-size: .8rem; color: #6c757d; margin-top: .2rem; }
    .workflow-arrow { font-size: 1.4rem; color: #adb5bd; display: flex; align-items: center; }
    .bar-before { background: #dc3545; }
    .bar-after  { background: #198754; }
    @@keyframes countUp { from { opacity:0; transform:scale(.85); } to { opacity:1; transform:scale(1); } }
    .pain-stat { animation: countUp .5s ease-out both; }
    .pain-stat:nth-child(1) { animation-delay: .1s; }
    .pain-stat:nth-child(2) { animation-delay: .25s; }
    .pain-stat:nth-child(3) { animation-delay: .4s; }
    .pain-stat:nth-child(4) { animation-delay: .55s; }
</style>

@* ── Header ── *@
<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <span class="badge bg-danger">Screen 1 of 7</span>
        <span class="badge bg-secondary">Today's Reality</span>
    </div>
    <h2 class="fw-bold mb-0">The Current State of Claim Attachments</h2>
    <p class="text-muted mb-0">Why the industry is moving to CMS-0053-F electronic attachments</p>
</div>

@* ── Pain stats row ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card border-danger h-100">
            <div class="card-body text-center py-3">
                <div class="pain-stat text-danger">21</div>
                <div class="stat-label">Days avg cycle time</div>
                <div class="text-muted small mt-1">Provider submits → payer decision</div>
                <div class="stat-source">Source: CAQH Index 2023</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-warning h-100">
            <div class="card-body text-center py-3">
                <div class="pain-stat text-warning">$3.60</div>
                <div class="stat-label">Cost per transaction</div>
                <div class="text-muted small mt-1">Manual vs. $0.24 electronic</div>
                <div class="stat-source">Source: CAQH Index 2023</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-danger h-100">
            <div class="card-body text-center py-3">
                <div class="pain-stat text-danger">26%</div>
                <div class="stat-label">Initial denial rate</div>
                <div class="text-muted small mt-1">Due to missing or incomplete attachments</div>
                <div class="stat-source">Source: AMA Prior Auth Survey</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-secondary h-100">
            <div class="card-body text-center py-3">
                <div class="pain-stat text-secondary">35%</div>
                <div class="stat-label">Still sent by fax</div>
                <div class="text-muted small mt-1">Or mail — unstructured, untracked</div>
                <div class="stat-source">Source: CAQH Index 2023</div>
            </div>
        </div>
    </div>
</div>

@* ── Manual workflow timeline ── *@
<div class="card mb-4">
    <div class="card-header py-2">
        <strong>The Manual Attachment Workflow — 14 to 21 Days</strong>
    </div>
    <div class="card-body">
        <div class="d-flex align-items-stretch gap-1 flex-wrap flex-lg-nowrap">
            <div class="workflow-step flex-fill">
                <div style="font-size:1.5rem">📋</div>
                <div class="fw-semibold small mt-1">Documentation Prepared</div>
                <div class="step-days">1–3 days</div>
                <div class="step-label">Provider staff gathers clinical notes, prints records</div>
            </div>
            <div class="workflow-arrow px-1">→</div>
            <div class="workflow-step flex-fill">
                <div style="font-size:1.5rem">📠</div>
                <div class="fw-semibold small mt-1">Faxed or Mailed</div>
                <div class="step-days">hours–1 day</div>
                <div class="step-label">No acknowledgement, no tracking, frequently lost</div>
            </div>
            <div class="workflow-arrow px-1">→</div>
            <div class="workflow-step flex-fill">
                <div style="font-size:1.5rem">📬</div>
                <div class="fw-semibold small mt-1">Payer Receives</div>
                <div class="step-days">1–3 days</div>
                <div class="step-label">Fax queue, physical mail room, manual sorting</div>
            </div>
            <div class="workflow-arrow px-1">→</div>
            <div class="workflow-step flex-fill">
                <div style="font-size:1.5rem">⌨️</div>
                <div class="fw-semibold small mt-1">Manual Data Entry</div>
                <div class="step-days">2–5 days</div>
                <div class="step-label">Staff keys metadata, links to claim — error-prone</div>
            </div>
            <div class="workflow-arrow px-1">→</div>
            <div class="workflow-step flex-fill">
                <div style="font-size:1.5rem">⏳</div>
                <div class="fw-semibold small mt-1">Adjudication Queue</div>
                <div class="step-days">5–9 days</div>
                <div class="step-label">Often re-requested; 26% denied on first pass</div>
            </div>
        </div>
    </div>
</div>

@* ── Before / After comparison ── *@
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card border-danger h-100">
            <div class="card-header py-2 bg-danger bg-opacity-10">
                <strong class="text-danger">❌ Without Electronic Attachments</strong>
            </div>
            <div class="card-body">
                <ul class="mb-0 small">
                    <li class="mb-2">Fax and mail — no structured data, no tracking</li>
                    <li class="mb-2">21-day average cycle time adds to working capital burden</li>
                    <li class="mb-2">3.2 FTE per 1,000 claims to manage attachment workflow</li>
                    <li class="mb-2">No audit trail — impossible to prove timely submission</li>
                    <li class="mb-2">26% initial denial rate drives costly appeals work</li>
                    <li class="mb-2">$3.60 per transaction vs. $0.24 electronic</li>
                    <li>Non-compliance with CMS-0053-F mandate — penalty exposure</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-success h-100">
            <div class="card-header py-2 bg-success bg-opacity-10">
                <strong class="text-success">✅ With iXDataBridge</strong>
            </div>
            <div class="card-body">
                <ul class="mb-0 small">
                    <li class="mb-2">X12 275 electronic submission — structured, acknowledged, tracked</li>
                    <li class="mb-2"><strong>4-hour</strong> cycle time — from provider submission to adjudication</li>
                    <li class="mb-2">Automated pipeline — no FTE required for intake or routing</li>
                    <li class="mb-2">SHA-256 cryptographic audit chain — tamper-evident, HIPAA-defensible</li>
                    <li class="mb-2">8-stage validation catches errors <em>before</em> claim adjudication</li>
                    <li class="mb-2">$0.24 per transaction — 93% cost reduction</li>
                    <li>CMS-0053-F compliant — mandate-ready by 2027 deadline</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@* ── Cycle time visual ── *@
<div class="card mb-4">
    <div class="card-header py-2"><strong>Cycle Time: Before vs. After</strong></div>
    <div class="card-body">
        <div class="mb-3">
            <div class="d-flex justify-content-between mb-1 small">
                <span class="fw-semibold text-danger">Manual (fax/mail)</span>
                <span class="text-danger fw-bold">21 days avg</span>
            </div>
            <div class="progress" style="height:28px; border-radius:4px">
                <div class="progress-bar bar-before" style="width:100%">
                    <span class="small fw-semibold">21 days &nbsp; ████████████████████</span>
                </div>
            </div>
        </div>
        <div>
            <div class="d-flex justify-content-between mb-1 small">
                <span class="fw-semibold text-success">iXDataBridge (electronic)</span>
                <span class="text-success fw-bold">4 hours</span>
            </div>
            <div class="progress" style="height:28px; border-radius:4px">
                <div class="progress-bar bar-after" style="width:2%">
                    <span class="small fw-semibold ps-1">4 hrs</span>
                </div>
            </div>
        </div>
        <div class="text-center mt-2 text-muted small">96% reduction in cycle time</div>
    </div>
</div>

@* ── Nav ── *@
<div class="d-flex justify-content-between">
    <a href="/" class="btn btn-outline-secondary">← Select Scenario</a>
    <a href="/Demo/Compliance" class="btn btn-outline-primary">Screen 2: Compliance Dashboard →</a>
</div>
