@page
@model Cms0053Demo.Pages.Demo.PipelineModel
@using Cms0053Demo.Models
@{
    ViewData["Title"] = "Validation Pipeline";
    var tx   = Model.Transaction;
    var scen = Model.Scenario;
    var color = scen?.Code switch { "A" => "primary", "B" => "danger", "C" => "warning", _ => "secondary" };
    var statusBadge = tx?.Status switch
    {
        TransactionStatus.Routed  => "bg-success",
        TransactionStatus.Failed  => "bg-danger",
        "UM Review"               => "bg-warning text-dark",
        _                         => "bg-secondary"
    };
    var passed = Model.StageDisplay.Where(s => s.Ran).All(s => s.Passed);
    var failedStage = Model.StageDisplay.FirstOrDefault(s => s.Ran && !s.Passed);
    var isScenarioBFailure = tx is not null && tx.Status == TransactionStatus.Failed && scen?.Code == "B";
}

<style>
    @@keyframes stageFadeIn {
        from { opacity: 0; transform: translateX(-6px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    .stage-anim {
        opacity: 0;
        animation: stageFadeIn 0.35s ease-out forwards;
    }
    .detail-json { font-size: .72rem; max-height: 200px; overflow-y: auto; background: #1e1e1e; color: #d4d4d4; border-radius: 4px; }
    .screen-nav-strip { border-bottom: 1px solid #dee2e6; padding-bottom: .75rem; margin-bottom: 1rem; }
</style>

@if (tx is null)
{
    <div class="mt-5 text-center text-muted">
        <p class="fs-5">No scenario selected.</p>
        <a href="/" class="btn btn-primary">Select a Scenario</a>
    </div>
}
else
{
    @* ── Scenario header ── *@
    <div class="card border-@color mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center flex-wrap gap-3">
                <span class="badge bg-@color fs-6 px-3 py-2">Scenario @scen!.Code</span>
                <div>
                    <div class="fw-semibold">@scen.Title</div>
                    <small class="text-muted">@tx.PatientName &nbsp;·&nbsp; @tx.ProviderName &nbsp;·&nbsp; @tx.ClaimNumber</small>
                </div>
                <div class="ms-auto text-end">
                    <span class="badge @statusBadge fs-6 px-3">@tx.Status</span>
                    <div class="font-monospace text-muted mt-1" style="font-size:.7rem">@tx.TrackingNumber</div>
                </div>
            </div>
        </div>
    </div>

    @* ── Screen navigation strip ── *@
    <div class="d-flex align-items-center gap-2 screen-nav-strip small">
        <a href="/Demo/TradingPartner?transactionId=@tx.Id" class="btn btn-sm btn-outline-secondary">
            ← Screen 3: Trading Partner Gateway
        </a>
        <span class="ms-auto text-muted">Screen <strong>4</strong> of 7 — Validation Pipeline</span>
        <a href="/Demo/Repository?transactionId=@tx.Id" class="btn btn-sm btn-outline-secondary">
            Screen 5: Document Repository →
        </a>
    </div>

    @* ── Pipeline stages ── *@
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center py-2">
            <strong>8-Stage Validation Pipeline</strong>
            @if (Model.TotalMs > 0)
            {
                <span class="ms-auto text-muted small">Total: @Model.TotalMs ms &nbsp;·&nbsp; @Model.StageDisplay.Count(s => s.Ran) stages executed</span>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:38px" class="ps-3">#</th>
                        <th>Stage</th>
                        <th style="width:90px">Status</th>
                        <th style="width:76px">Duration</th>
                        <th style="width:68px"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.StageDisplay.Count; i++)
                    {
                        var s = Model.StageDisplay[i];
                        var delay = (i * 0.14).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                        <tr class="stage-anim @s.RowClass" style="animation-delay:@(delay)s">
                            <td class="ps-3 fw-bold text-muted">@s.Order</td>
                            <td>@s.Name</td>
                            <td>
                                @if (s.Ran)
                                {
                                    <span class="badge @s.BadgeClass">@s.StatusLabel</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-muted small">@s.Duration</td>
                            <td>
                                @if (s.Ran)
                                {
                                    <button class="btn btn-link btn-sm p-0 text-decoration-none text-secondary"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#detail-@s.Order">detail</button>
                                }
                            </td>
                        </tr>
                        @if (s.Ran && !s.Passed && !string.IsNullOrEmpty(s.ErrorText))
                        {
                            var errDelay = (i * 0.14 + 0.07).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                            <tr class="table-danger stage-anim" style="animation-delay:@(errDelay)s">
                                <td colspan="5" class="ps-4 py-2">
                                    <i class="text-danger fw-semibold">Error:</i> @s.ErrorText
                                </td>
                            </tr>
                        }
                        @if (s.Ran)
                        {
                            <tr class="collapse" id="detail-@s.Order">
                                <td colspan="5" class="p-0">
                                    <div class="p-3 border-top">
                                        <pre class="detail-json p-2 mb-0">@PipelineModel.PrettyJson(s.Result?.Detail)</pre>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── Result summary ── *@
    <div class="mt-3 stage-anim" style="animation-delay:1.3s">
        @if (passed && failedStage is null)
        {
            <div class="alert alert-success d-flex align-items-center gap-3 mb-0">
                <span style="font-size:1.8rem">✅</span>
                <div>
                    <strong class="fs-5">Attachment Accepted</strong>
                    <div>All 8 validation stages passed &nbsp;·&nbsp;
                        Claim <strong>@tx.ClaimNumber</strong> matched &nbsp;·&nbsp;
                        <strong>$@scen!.ClaimAmount.ToString("N0")</strong>
                    </div>
                </div>
                <div class="ms-auto">
                    <a href="/Demo/Repository?transactionId=@tx.Id" class="btn btn-success">
                        View in Repository →
                    </a>
                </div>
            </div>
        }
        else if (tx.Status == "UM Review")
        {
            <div class="alert alert-warning d-flex align-items-center gap-3 mb-0">
                <span style="font-size:1.8rem">⏳</span>
                <div>
                    <strong class="fs-5">Routed for UM Review</strong>
                    <div>All technical stages passed &nbsp;·&nbsp; Clinical policy review required</div>
                </div>
                <div class="ms-auto">
                    <a href="/Demo/ClaimsHandoff?transactionId=@tx.Id" class="btn btn-warning">
                        Claims Handoff →
                    </a>
                </div>
            </div>
        }
        else if (failedStage is not null)
        {
            <div class="alert alert-danger mb-0">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size:1.8rem">❌</span>
                    <div>
                        <strong class="fs-5">Attachment Rejected</strong>
                        <div>Failed at <strong>Stage @failedStage.Order: @failedStage.Name</strong></div>
                        @if (!string.IsNullOrEmpty(failedStage.ErrorText))
                        {
                            <div class="mt-1 text-danger">@failedStage.ErrorText</div>
                        }
                    </div>
                    @if (isScenarioBFailure)
                    {
                        <div class="ms-auto">
                            <form method="post" asp-page-handler="Resubmit">
                                <input type="hidden" name="scenarioId" value="@scen!.Id" />
                                <button type="submit" class="btn btn-outline-danger">
                                    Resubmit with Corrected CDA →
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
