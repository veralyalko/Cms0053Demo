@page
@model Cms0053Demo.Pages.Demo.ComplianceModel
@{ ViewData["Title"] = "Compliance Dashboard"; }

<style>
    .meta-label { font-size:.7rem; text-transform:uppercase; letter-spacing:.06em; color:#6c757d; font-weight:600; }
    .req-row { border-left: 4px solid transparent; padding: .5rem .75rem; border-radius: 0 4px 4px 0; }
    .req-row.met     { border-color: #198754; background: #f0fff4; }
    .req-row.gap     { border-color: #dc3545; background: #fff5f5; }
    .req-row.partial { border-color: #fd7e14; background: #fffbf5; }
    .timeline-dot { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; margin-top: 3px; }
    .timeline-line { width: 2px; background: #dee2e6; margin: 2px auto; flex-shrink: 0; }
    .readiness-score { font-size: 3.2rem; font-weight: 700; line-height: 1; }
</style>

@* ── Header ── *@
<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-1">
        <span class="badge bg-warning text-dark">Screen 2 of 7</span>
        <span class="badge bg-secondary">Compliance Dashboard</span>
    </div>
    <h2 class="fw-bold mb-0">CMS-0053-F Compliance Readiness</h2>
    <p class="text-muted mb-0">Mandate timeline, gap assessment, and business case for Meridian Health Plan</p>
</div>

@* ── Live counters (if any transactions have run) ── *@
@if (Model.TotalTransactions > 0)
{
    <div class="alert alert-success d-flex align-items-center gap-3 mb-4 py-2">
        <span style="font-size:1.4rem">⚡</span>
        <div class="small">
            <strong>Platform active this session:</strong>
            &nbsp;@Model.TotalTransactions attachment@(Model.TotalTransactions != 1 ? "s" : "") processed
            &nbsp;·&nbsp; @Model.PassedTransactions routed to adjudication
            @if (Model.FailedTransactions > 0)
            {
                <span>&nbsp;·&nbsp; @Model.FailedTransactions rejected (validation errors surfaced)</span>
            }
        </div>
    </div>
}

<div class="row g-3 mb-4">

    @* ── Readiness score ── *@
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header py-2"><strong>Readiness Score</strong></div>
            <div class="card-body text-center py-4">
                <div class="mb-3">
                    <div class="meta-label mb-1">Without iXDataBridge</div>
                    <div class="readiness-score text-danger">23%</div>
                    <div class="progress mt-2" style="height:10px">
                        <div class="progress-bar bg-danger" style="width:23%"></div>
                    </div>
                </div>
                <div class="text-muted my-2" style="font-size:1.5rem">↓</div>
                <div>
                    <div class="meta-label mb-1">With iXDataBridge</div>
                    <div class="readiness-score text-success">96%</div>
                    <div class="progress mt-2" style="height:10px">
                        <div class="progress-bar bg-success" style="width:96%"></div>
                    </div>
                </div>
                <div class="mt-3 small text-muted">Based on CMS-0053-F requirement mapping</div>
            </div>
        </div>
    </div>

    @* ── Mandate timeline ── *@
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header py-2"><strong>CMS-0053-F Mandate Timeline</strong></div>
            <div class="card-body py-3">
                @{
                    var milestones = new[]
                    {
                        ("Dec 2023", "CMS proposes mandatory electronic claim attachments", "past", "Proposed rule published in Federal Register"),
                        ("2024",     "Comment period — industry responds to proposal",       "past", "Payers and providers submit comments"),
                        ("2026",     "Final rule effective — compliance preparation required","warn", "Health plans must begin implementation planning"),
                        ("Jan 2027", "Large health plans: X12 275 support required",          "crit", "Non-compliance: HIPAA penalty exposure"),
                        ("Jan 2028", "All covered plans: full compliance deadline",            "crit", "Mandatory for all plan sizes"),
                    };
                }
                @foreach (var (date, title, status, detail) in milestones)
                {
                    var dotColor = status switch { "past" => "#adb5bd", "warn" => "#fd7e14", _ => "#dc3545" };
                    var textClass = status switch { "past" => "text-muted", "warn" => "text-warning", _ => "text-danger" };
                    <div class="d-flex gap-2 mb-2">
                        <div>
                            <div class="timeline-dot mt-1" style="background:@dotColor"></div>
                            @if (date != milestones[^1].Item1)
                            {
                                <div class="timeline-line" style="height:28px"></div>
                            }
                        </div>
                        <div>
                            <div class="small fw-semibold @textClass">@date</div>
                            <div class="small">@title</div>
                            <div class="text-muted" style="font-size:.7rem">@detail</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Penalty / ROI summary ── *@
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header py-2"><strong>Business Case</strong></div>
            <div class="card-body py-3">
                <div class="mb-3 p-2 rounded bg-danger bg-opacity-10">
                    <div class="meta-label text-danger">Penalty Risk (Non-Compliance)</div>
                    <div class="fw-bold">Up to $100/day per violation</div>
                    <div class="small text-muted">HIPAA civil money penalty — per covered entity</div>
                </div>
                <div class="mb-3 p-2 rounded bg-success bg-opacity-10">
                    <div class="meta-label text-success">Cost Reduction</div>
                    <div class="fw-bold">$3.36 saved per transaction</div>
                    <div class="small text-muted">$3.60 manual → $0.24 electronic (CAQH)</div>
                </div>
                <div class="mb-3 p-2 rounded bg-primary bg-opacity-10">
                    <div class="meta-label text-primary">Cycle Time</div>
                    <div class="fw-bold">21 days → 4 hours</div>
                    <div class="small text-muted">96% reduction in attachment processing time</div>
                </div>
                <div class="p-2 rounded bg-warning bg-opacity-10">
                    <div class="meta-label text-warning">Denial Reduction</div>
                    <div class="fw-bold">26% → &lt;3% initial denial rate</div>
                    <div class="small text-muted">Structured validation catches errors pre-submission</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Gap assessment ── *@
<div class="card mb-4">
    <div class="card-header py-2"><strong>CMS-0053-F Requirement Gap Assessment</strong></div>
    <div class="card-body pb-2">
        <div class="row g-2">
            @{
                var reqs = new[]
                {
                    ("X12 275 Electronic Attachment Receipt",         "gap",     "met",     "No structured X12 ingestion",         "Full X12 275 envelope parse + segment validation"),
                    ("CDA R2 / C-CDA Document Validation",           "gap",     "met",     "PDF/fax only — no structured format",  "Real CDA schema + C-CDA template validation"),
                    ("LOINC Document Type Classification",            "gap",     "met",     "Manual classification, error-prone",   "Automated LOINC lookup with 12-code subset"),
                    ("Digital Signature Verification (XMLDSig)",      "gap",     "met",     "No signature support",                "RSA-2048/SHA-256 XMLDSig enveloped signature verify"),
                    ("Real-Time Claim Matching (ICN/TCN linkage)",    "gap",     "met",     "Days-long manual matching process",    "Automated matching via X12 TRN02 + NM1*41 NPI"),
                    ("Tamper-Evident Audit Trail",                    "partial", "met",     "Basic access logs only",              "SHA-256 cryptographic hash chain — blockchain-style"),
                    ("Trading Partner Enrollment + Authentication",   "partial", "met",     "Manual enrollment, no AS2 support",    "SFTP key + AS2 MDN acknowledgement workflow"),
                    ("Clearinghouse Connectivity",                    "gap",     "partial", "No clearinghouse integration",         "Veridian Health Exchange connector (in scope)"),
                };
            }
            @foreach (var (req, before, after, beforeNote, afterNote) in reqs)
            {
                <div class="col-12">
                    <div class="row g-1 align-items-center">
                        <div class="col-lg-4 small fw-semibold">@req</div>
                        <div class="col-lg-4">
                            <div class="req-row @before">
                                <span class="badge @(before == "gap" ? "bg-danger" : before == "partial" ? "bg-warning text-dark" : "bg-success") me-1"
                                      style="font-size:.62rem">@(before == "gap" ? "Gap" : before == "partial" ? "Partial" : "Met")</span>
                                <span style="font-size:.75rem">@beforeNote</span>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="req-row @after">
                                <span class="badge @(after == "met" ? "bg-success" : "bg-warning text-dark") me-1"
                                      style="font-size:.62rem">@(after == "met" ? "Met" : "In Scope")</span>
                                <span style="font-size:.75rem">@afterNote</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-muted mt-2" style="font-size:.7rem">
            Left column: current state without platform &nbsp;·&nbsp; Right column: with iXDataBridge deployed
        </div>
    </div>
</div>

@* ── Nav ── *@
<div class="d-flex justify-content-between">
    <a href="/Demo/TodaysReality" class="btn btn-outline-secondary">← Screen 1: Today's Reality</a>
    <a href="/" class="btn btn-primary">Start the Demo →</a>
</div>
