@page
@model Cms0053Demo.Pages.Demo.ClaimsHandoffModel
@using Cms0053Demo.Models
@{
    ViewData["Title"] = "Claims + UM Handoff";
    var tx   = Model.Transaction;
    var scen = Model.Scenario;
    var info = Model.MatchInfo;
    var color = scen?.Code switch { "A" => "primary", "B" => "danger", "C" => "warning", _ => "secondary" };
    var isUm = tx?.Status == "UM Review";
    var isFailed = tx?.Status == TransactionStatus.Failed;
}

<style>
    .meta-label { font-size:.7rem; text-transform:uppercase; letter-spacing:.06em; color:#6c757d; font-weight:600; }
    .routing-badge { font-size:1.1rem; font-weight:700; letter-spacing:.02em; }
    .detail-json { font-size:.72rem; background:#1e1e1e; color:#d4d4d4; border-radius:4px; max-height:180px; overflow-y:auto; }
</style>

@if (tx is null)
{
    <div class="mt-5 text-center text-muted">
        <p class="fs-5">No transaction loaded.</p>
        <a href="/" class="btn btn-primary">Select a Scenario</a>
    </div>
}
else
{
    @* ── Scenario header ── *@
    <div class="card border-@color mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center flex-wrap gap-3">
                <span class="badge bg-@color fs-6 px-3 py-2">Scenario @scen!.Code</span>
                <div>
                    <div class="fw-semibold">@scen.Title</div>
                    <small class="text-muted">@tx.PatientName &nbsp;·&nbsp; @tx.ProviderName &nbsp;·&nbsp; @tx.ClaimNumber</small>
                </div>
                <div class="ms-auto text-end">
                    @if (isUm)
                    {
                        <span class="badge bg-warning text-dark fs-6 px-3">UM Review</span>
                    }
                    else if (!isFailed)
                    {
                        <span class="badge bg-success fs-6 px-3">Routed</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6 px-3">Failed</span>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Screen nav ── *@
    <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom small">
        <a href="/Demo/Repository?transactionId=@tx.Id" class="btn btn-sm btn-outline-secondary">← Screen 5: Document Repository</a>
        <span class="ms-auto text-muted">Screen <strong>6</strong> of 7 — Claims + UM Handoff</span>
        <a href="/Demo/AuditTrail?transactionId=@tx.Id" class="btn btn-sm btn-outline-secondary">Screen 7: Audit Trail →</a>
    </div>

    @* ── Routing status banner ── *@
    @if (isUm)
    {
        <div class="alert alert-warning d-flex align-items-center gap-3 mb-3">
            <span style="font-size:2rem">⏳</span>
            <div>
                <div class="routing-badge">ROUTED TO CLINICAL REVIEW</div>
                <div class="mt-1">Case <strong>@tx.ClaimNumber</strong> has been queued for Utilization Management review</div>
            </div>
        </div>
    }
    else if (!isFailed)
    {
        <div class="alert alert-success d-flex align-items-center gap-3 mb-3">
            <span style="font-size:2rem">✅</span>
            <div>
                <div class="routing-badge">CLAIM ROUTED FOR ADJUDICATION</div>
                <div class="mt-1">Claim <strong>@(info?.ClaimNumber ?? tx.ClaimNumber)</strong> has been sent to the auto-adjudication queue</div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger d-flex align-items-center gap-3 mb-3">
            <span style="font-size:2rem">❌</span>
            <div>
                <div class="routing-badge">ATTACHMENT REJECTED — NOT ROUTED</div>
                <div class="mt-1">Validation failed — attachment was not forwarded to adjudication</div>
            </div>
        </div>
    }

    @* ── Two-column: matched claim + routing details ── *@
    <div class="row g-3 mb-3">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header py-2"><strong>Matched Claim</strong></div>
                <div class="card-body py-3">
                    @if (info is not null)
                    {
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="meta-label">Claim Number</div>
                                <div class="font-monospace small">@info.ClaimNumber</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Billed Amount</div>
                                <div class="fw-bold text-success">$@info.ClaimAmount.ToString("N0")</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Patient</div>
                                <div class="small">@info.PatientName</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Provider</div>
                                <div class="small">@info.ProviderName</div>
                            </div>
                            <div class="col-12">
                                <div class="meta-label">Match Method</div>
                                <div class="small text-muted">@info.MatchMethod</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Stage Duration</div>
                                <div class="small">@(Model.ClaimMatchStage?.DurationMs)ms</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Result</div>
                                <div class="small">
                                    <span class="badge bg-success">Matched</span>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No claim match data available</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            @if (isUm)
            {
                <div class="card h-100 border-warning">
                    <div class="card-header py-2 bg-warning bg-opacity-10"><strong>UM Review Queue</strong></div>
                    <div class="card-body py-3">
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="meta-label">Queue</div>
                                <div class="small fw-semibold">Clinical Review</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Priority</div>
                                <div class="small"><span class="badge bg-warning text-dark">Prior Auth Required</span></div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Assigned To</div>
                                <div class="small">UM Clinical Team</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Turnaround</div>
                                <div class="small">2 business days</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Clinician</div>
                                <div class="small">@scen.ClinicianName</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Document</div>
                                <div class="small">@tx.DocumentType</div>
                            </div>
                            <div class="col-12">
                                <div class="meta-label">Criteria</div>
                                <div class="small text-muted">InterQual / MCG clinical criteria applied</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (!isFailed)
            {
                <div class="card h-100 border-success">
                    <div class="card-header py-2 bg-success bg-opacity-10"><strong>Adjudication Queue</strong></div>
                    <div class="card-body py-3">
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="meta-label">Queue</div>
                                <div class="small fw-semibold">Auto-Adjudication</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Priority</div>
                                <div class="small"><span class="badge bg-secondary">Standard</span></div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Expected Decision</div>
                                <div class="small text-success fw-semibold">Approve</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Criteria</div>
                                <div class="small">Medical Necessity</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Payment Est.</div>
                                <div class="small fw-semibold">$@((info?.ClaimAmount * 0.82m ?? 0).ToString("N0"))</div>
                            </div>
                            <div class="col-6">
                                <div class="meta-label">Remittance</div>
                                <div class="small">ERA 835 — 14 days</div>
                            </div>
                            <div class="col-12">
                                <div class="meta-label">Routing</div>
                                <div class="small text-muted">CMS-0053 compliant — attachment linked via claim ICN</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card h-100 border-danger">
                    <div class="card-header py-2"><strong>Not Routed</strong></div>
                    <div class="card-body py-2">
                        <div class="text-danger">Attachment failed validation and was not forwarded to claims processing.</div>
                        <div class="mt-2 small text-muted">Return to the pipeline and resubmit with a corrected document.</div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── Stage 7 detail ── *@
    @if (!string.IsNullOrEmpty(Model.ClaimMatchDetail))
    {
        <div class="card mb-3">
            <div class="card-header py-2">
                <strong>Stage 7: Claim Match — Detail</strong>
                <span class="ms-2 text-muted small">@(Model.ClaimMatchStage?.DurationMs)ms</span>
            </div>
            <div class="card-body p-0">
                <pre class="detail-json p-3 mb-0">@Model.ClaimMatchDetail</pre>
            </div>
        </div>
    }

    <div class="d-flex justify-content-end">
        <a href="/Demo/AuditTrail?transactionId=@tx.Id" class="btn btn-primary">
            View Audit Trail →
        </a>
    </div>
}
