@page
@model Cms0053Demo.Pages.Demo.TradingPartnerModel
@using Cms0053Demo.Models
@{
    ViewData["Title"] = "Trading Partner Gateway";
    var tx   = Model.Transaction;
    var scen = Model.Scenario;
    var x12  = Model.X12Result;
    var color = scen?.Code switch { "A" => "primary", "B" => "danger", "C" => "warning", _ => "secondary" };
}

<style>
    .x12-terminal {
        background: #1a1a2e;
        color: #e0e0e0;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: .78rem;
        line-height: 1.7;
        border-radius: 6px;
        padding: 1rem 1.25rem;
        overflow-x: auto;
    }
    .seg-line:hover { background: rgba(255,255,255,.05); border-radius: 3px; }
    .seg-id { font-weight: 700; min-width: 2.5rem; display: inline-block; }
    .seg-sep { color: #555; }
    .seg-term { color: #555; }
    .field-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; color: #6c757d; font-weight: 600; }
</style>

@if (tx is null)
{
    <div class="mt-5 text-center text-muted">
        <p class="fs-5">No transaction loaded. Run a scenario first.</p>
        <a href="/" class="btn btn-primary">Select a Scenario</a>
    </div>
}
else
{
    @* ── Scenario header ── *@
    <div class="card border-@color mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center flex-wrap gap-3">
                <span class="badge bg-@color fs-6 px-3 py-2">Scenario @scen!.Code</span>
                <div>
                    <div class="fw-semibold">@scen.Title</div>
                    <small class="text-muted">
                        X12 275 Attachment Transaction received from
                        <strong>@(x12?.SenderId ?? scen.ProviderNPI)</strong>
                    </small>
                </div>
                <div class="ms-auto">
                    <span class="badge bg-success">✓ Received</span>
                    <div class="font-monospace text-muted mt-1" style="font-size:.7rem">@tx.TrackingNumber</div>
                </div>
            </div>
        </div>
    </div>

    @* ── Screen navigation strip ── *@
    <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom small">
        <a href="/" class="btn btn-sm btn-outline-secondary">← Home</a>
        <span class="ms-auto text-muted">Screen <strong>3</strong> of 7 — Trading Partner Gateway</span>
        <a href="/Demo/Pipeline?transactionId=@tx.Id" class="btn btn-sm btn-outline-primary">
            Screen 4: Validation Pipeline →
        </a>
    </div>

    @* ── Two-column layout ── *@
    <div class="row g-3">

        @* LEFT: X12 envelope terminal *@
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header py-2 d-flex align-items-center">
                    <strong>X12 275 Transaction Set</strong>
                    <span class="ms-auto badge bg-dark">@Model.DisplaySegments.Count segments</span>
                </div>
                <div class="card-body p-0">
                    <div class="x12-terminal">
                        @foreach (var seg in Model.DisplaySegments)
                        {
                            <div class="seg-line">
                                <span class="seg-id @seg.CssClass">@seg.Id</span>
                                @foreach (var elem in seg.Elements)
                                {
                                    <span class="seg-sep">*</span><span>@elem</span>
                                }
                                <span class="seg-term">~</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* RIGHT: Parsed fields *@
        <div class="col-lg-5">

            @* Connection info *@
            <div class="card mb-3">
                <div class="card-header py-2"><strong>Interchange Control</strong></div>
                <div class="card-body py-2">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="field-label">Sender ID</div>
                            <div class="font-monospace small">@(x12?.SenderId ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Receiver ID</div>
                            <div class="font-monospace small">@(x12?.ReceiverId ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Control #</div>
                            <div class="font-monospace small">@(x12?.ControlNumber ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Tx Type</div>
                            <div class="font-monospace small">
                                @if (x12?.TransactionType == "275")
                                {
                                    <span class="badge bg-success">275</span>
                                }
                                else
                                {
                                    <span>@(x12?.TransactionType ?? "—")</span>
                                }
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Date</div>
                            <div class="font-monospace small">@(x12?.TransactionDate ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Time</div>
                            <div class="font-monospace small">@(x12?.TransactionTime ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            @* Provider info *@
            <div class="card mb-3">
                <div class="card-header py-2"><strong>Submitting Provider (NM1*41)</strong></div>
                <div class="card-body py-2">
                    <div class="row g-2">
                        <div class="col-12">
                            <div class="field-label">Provider Name</div>
                            <div class="small">@(x12?.ProviderName ?? "—")</div>
                        </div>
                        <div class="col-12">
                            <div class="field-label">NPI</div>
                            <div class="font-monospace small">@(x12?.ProviderNPI ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            @* Patient info *@
            <div class="card mb-3">
                <div class="card-header py-2"><strong>Patient (NM1*QC + DMG)</strong></div>
                <div class="card-body py-2">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="field-label">Last Name</div>
                            <div class="small">@(x12?.PatientLastName ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">First Name</div>
                            <div class="small">@(x12?.PatientFirstName ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">DOB (DMG)</div>
                            <div class="font-monospace small">@(x12?.PatientDob ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Gender</div>
                            <div class="small">@(x12?.PatientGender ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            @* Claim reference *@
            <div class="card mb-3">
                <div class="card-header py-2"><strong>Claim Reference (TRN)</strong></div>
                <div class="card-body py-2">
                    <div class="field-label">Claim Number</div>
                    <div class="font-monospace small">@(x12?.ClaimNumber ?? "—")</div>
                    <div class="field-label mt-2">Tracking Number (BHT03)</div>
                    <div class="font-monospace small">@(x12?.TrackingNumber ?? "—")</div>
                </div>
            </div>

            @* Auth status *@
            <div class="card border-success">
                <div class="card-body py-2 d-flex align-items-center gap-2">
                    <span class="text-success fw-bold" style="font-size:1.3rem">✓</span>
                    <div>
                        <div class="fw-semibold text-success">Trading Partner Authenticated</div>
                        <small class="text-muted">SFTP key verified &nbsp;·&nbsp; AS2 MDN acknowledged &nbsp;·&nbsp; ISA13 unique</small>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-grid">
                <a href="/Demo/Pipeline?transactionId=@tx.Id" class="btn btn-primary">
                    Run Validation Pipeline →
                </a>
            </div>
        </div>
    </div>
}
