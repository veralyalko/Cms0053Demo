@page
@model Cms0053Demo.Pages.Presenter.ConsoleModel
@{
    ViewData["Title"] = "Presenter Console";
}

<style>
    body { background: #0d0d1a; }
    .console-wrap { color: #e0e0e0; }
    .console-header { background: #1a1a2e; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
    .timer-block { font-family: 'Consolas','Courier New',monospace; font-size: 1.4rem; font-weight: 700; line-height: 1; }
    .screen-pill { font-size: .78rem; font-weight: 600; }
    .talk-track { font-size: .93rem; line-height: 1.75; color: #d0d0e8; }
    .qa-q { font-weight: 600; color: #ffc107; font-size: .85rem; cursor: pointer; }
    .qa-a { font-size: .83rem; color: #a8c8a8; padding: .5rem .75rem; background: rgba(255,255,255,.05); border-radius: 4px; border-left: 3px solid #198754; }
    .scenario-card { border: 1px solid #333; border-radius: 6px; padding: .6rem .9rem; cursor: pointer; transition: border-color .15s; }
    .scenario-card.active-a { border-color: #198754; background: rgba(25,135,84,.1); }
    .scenario-card.active-b { border-color: #ffc107; background: rgba(255,193,7,.08); }
    .scenario-card.active-c { border-color: #0d6efd; background: rgba(13,110,253,.1); }
    .nav-pill-dark .nav-link { color: #adb5bd; border-radius: 4px; }
    .nav-pill-dark .nav-link:hover { color: #fff; background: rgba(255,255,255,.08); }
    .nav-pill-dark .nav-link.active { color: #fff !important; background: #0d6efd !important; }
    .quick-link { font-size:.8rem; }
    .tx-row { font-size:.78rem; }
</style>

<div class="console-wrap">

    @* ── Console header ── *@
    <div class="console-header">
        <div class="d-flex align-items-center flex-wrap gap-3">
            <div>
                <span class="fw-bold text-white fs-5">PRESENTER CONSOLE</span>
                <span class="badge bg-warning text-dark ms-2" style="font-size:.65rem">NOT VISIBLE TO AUDIENCE</span>
            </div>
            <div class="ms-auto d-flex align-items-center gap-4">
                <div class="text-center">
                    <div class="text-muted" style="font-size:.65rem; text-transform:uppercase; letter-spacing:.08em">Elapsed</div>
                    <div class="timer-block text-white" id="elapsed">00:00</div>
                </div>
                <div class="text-center">
                    <div class="text-muted" style="font-size:.65rem; text-transform:uppercase; letter-spacing:.08em">Remaining</div>
                    <div class="timer-block" id="remaining">12:00</div>
                </div>
                <button id="resetTimer" class="btn btn-sm btn-outline-secondary">Reset Timer</button>
                <a href="/" class="btn btn-sm btn-outline-warning">← Home</a>
            </div>
        </div>
    </div>

    <div class="row g-3">

        @* ── Left: Screen selector + quick nav ── *@
        <div class="col-lg-3">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-header border-secondary py-2">
                    <span class="text-muted small fw-semibold">SCREEN NAVIGATOR</span>
                </div>
                <div class="card-body p-2">
                    <ul class="nav flex-column nav-pill-dark gap-1" id="screenTabs">
                        @foreach (var s in ConsoleModel.AllScreens)
                        {
                            <li class="nav-item">
                                <button class="nav-link w-100 text-start screen-pill @(s.Number == 1 ? "active" : "")"
                                        data-bs-toggle="pill"
                                        data-bs-target="#screen-@s.Number">
                                    <span class="badge bg-secondary me-2" style="min-width:18px">@s.Number</span>
                                    @s.Title
                                </button>
                            </li>
                        }
                    </ul>
                </div>

                <div class="card-header border-secondary py-2 mt-2">
                    <span class="text-muted small fw-semibold">QUICK OPEN (NEW TAB)</span>
                </div>
                <div class="card-body p-2">
                    @foreach (var s in ConsoleModel.AllScreens)
                    {
                        <a href="@Model.TxUrl(s.Number)"
                           target="_blank"
                           class="btn btn-sm btn-outline-secondary w-100 text-start mb-1 quick-link">
                            <span class="badge bg-secondary me-1">@s.Number</span>
                            Open @s.Title
                        </a>
                    }
                </div>
            </div>
        </div>

        @* ── Center: Talk track ── *@
        <div class="col-lg-5">
            <div class="tab-content h-100">
                @foreach (var s in ConsoleModel.AllScreens)
                {
                    <div class="tab-pane fade @(s.Number == 1 ? "show active" : "")" id="screen-@s.Number">
                        <div class="card bg-dark border-secondary h-100">
                            <div class="card-header border-secondary py-2 d-flex align-items-center">
                                <span class="badge bg-primary me-2">Screen @s.Number</span>
                                <strong class="text-white">@s.Title</strong>
                                <a href="@Model.TxUrl(s.Number)" target="_blank"
                                   class="btn btn-sm btn-outline-primary ms-auto py-0">Open →</a>
                            </div>
                            <div class="card-body">
                                <div class="text-muted mb-2" style="font-size:.7rem; text-transform:uppercase; letter-spacing:.08em">Talk Track</div>
                                <div class="talk-track">@s.TalkTrack</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ── Right: Q&A + scenario selector ── *@
        <div class="col-lg-4">
            <div class="tab-content mb-3">
                @foreach (var s in ConsoleModel.AllScreens)
                {
                    <div class="tab-pane fade @(s.Number == 1 ? "show active" : "")" id="qa-@s.Number">
                        <div class="card bg-dark border-secondary">
                            <div class="card-header border-secondary py-2">
                                <span class="text-muted small fw-semibold">ANTICIPATED QUESTIONS</span>
                            </div>
                            <div class="card-body p-2">
                                @for (var i = 0; i < s.QandA.Length; i++)
                                {
                                    var (q, a) = s.QandA[i];
                                    var collapseId = $"qa-{s.Number}-{i}";
                                    <div class="mb-3">
                                        <div class="qa-q d-flex align-items-start gap-2"
                                             data-bs-toggle="collapse"
                                             data-bs-target="#@collapseId">
                                            <span class="badge bg-warning text-dark mt-1" style="font-size:.6rem; flex-shrink:0">Q@(i+1)</span>
                                            @q
                                        </div>
                                        <div class="collapse mt-2" id="@collapseId">
                                            <div class="qa-a">@a</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* ── Scenario selector ── *@
            <div class="card bg-dark border-secondary mb-3">
                <div class="card-header border-secondary py-2">
                    <span class="text-muted small fw-semibold">SCENARIO SELECTOR</span>
                </div>
                <div class="card-body p-2">
                    <div class="row g-2">
                        @foreach (var scen in Model.Scenarios)
                        {
                            var cardClass = scen.Code switch { "A" => "active-a", "B" => "active-b", _ => "active-c" };
                            var typeLabel = scen.ScenarioType switch { "HappyPath" => "Happy Path ✓", "DeliberateFailure" => "Failure + Recovery", _ => "UM Review" };
                            Model.LastByScenario.TryGetValue(scen.Code, out var lastTx);
                            <div class="col-12">
                                <div class="scenario-card @cardClass">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge @(scen.Code == "A" ? "bg-success" : scen.Code == "B" ? "bg-warning text-dark" : "bg-primary")">@scen.Code</span>
                                        <div class="flex-grow-1">
                                            <div class="text-white small fw-semibold">@scen.Title</div>
                                            <div class="text-muted" style="font-size:.7rem">@typeLabel &nbsp;·&nbsp; @scen.ClaimNumber</div>
                                        </div>
                                        <a href="/Demo/Pipeline?scenarioId=@scen.Id"
                                           target="_blank"
                                           class="btn btn-sm @(scen.Code == "A" ? "btn-outline-success" : scen.Code == "B" ? "btn-outline-warning" : "btn-outline-primary") py-0"
                                           style="font-size:.72rem">Run →</a>
                                    </div>
                                    @if (lastTx != null)
                                    {
                                        <div class="tx-row text-muted mt-1 d-flex gap-2">
                                            <span class="font-monospace">@lastTx.TrackingNumber</span>
                                            <span class="badge @(lastTx.Status is "Routed" or "UM Review" ? "bg-success" : lastTx.Status == "Failed" ? "bg-danger" : "bg-secondary") ms-auto" style="font-size:.6rem">@lastTx.Status</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="tx-row text-muted mt-1">No runs this session</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ── Demo flow summary ── *@
            <div class="card bg-dark border-secondary">
                <div class="card-header border-secondary py-2">
                    <span class="text-muted small fw-semibold">12-MINUTE FLOW</span>
                </div>
                <div class="card-body p-2">
                    <ol class="mb-0 ps-3" style="font-size:.75rem; color:#adb5bd; line-height:1.8">
                        <li><span class="text-warning">0:00</span> — Open Screen 1: The pain state</li>
                        <li><span class="text-warning">1:30</span> — Screen 2: Compliance mandate</li>
                        <li><span class="text-warning">3:00</span> — <strong class="text-white">Run Scenario A</strong> → Screen 3: X12 envelope</li>
                        <li><span class="text-warning">5:00</span> — Screen 4: Watch pipeline run</li>
                        <li><span class="text-warning">7:00</span> — Screen 5: Signed document</li>
                        <li><span class="text-warning">8:30</span> — Screen 6: Claim routed</li>
                        <li><span class="text-warning">10:00</span> — Screen 7: Hash chain</li>
                        <li><span class="text-warning">11:00</span> — <strong class="text-white">Run Scenario B</strong>: failure + resubmit</li>
                        <li><span class="text-success">12:00</span> — Questions</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const TOTAL = 12 * 60;
    const key = 'cms0053_console_start';

    let start = sessionStorage.getItem(key);
    if (!start) {
        start = Date.now();
        sessionStorage.setItem(key, start);
    } else {
        start = parseInt(start);
    }

    function fmt(s) {
        return String(Math.floor(s / 60)).padStart(2, '0') + ':' + String(s % 60).padStart(2, '0');
    }

    function tick() {
        const elapsed = Math.floor((Date.now() - start) / 1000);
        const remaining = Math.max(0, TOTAL - elapsed);
        document.getElementById('elapsed').textContent = fmt(elapsed);
        const remEl = document.getElementById('remaining');
        remEl.textContent = fmt(remaining);
        remEl.className = 'timer-block ' + (remaining < 120 ? 'text-danger' : remaining < 300 ? 'text-warning' : 'text-success');
    }

    tick();
    setInterval(tick, 1000);

    document.getElementById('resetTimer').addEventListener('click', function () {
        sessionStorage.setItem(key, Date.now());
        location.reload();
    });

    // Sync Q&A tab pane with the screen pill selection
    document.querySelectorAll('[data-bs-target^="#screen-"]').forEach(function (btn) {
        btn.addEventListener('shown.bs.tab', function (e) {
            const num = e.target.getAttribute('data-bs-target').replace('#screen-', '');
            // Activate matching Q&A pane
            const qaPane = document.getElementById('qa-' + num);
            if (qaPane) {
                document.querySelectorAll('[id^="qa-"]').forEach(function (p) {
                    p.classList.remove('show', 'active');
                });
                qaPane.classList.add('show', 'active');
            }
        });
    });
}());
</script>
}
